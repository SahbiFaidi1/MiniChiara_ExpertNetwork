# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Public URL Slack can reach (ngrok / cloudflared / deployed)
PUBLIC_BASE_URL=https://example.ngrok-free.app

# --- Server ---
PORT=8000
LOG_LEVEL=INFO

# --- Database (Supabase Postgres or local Postgres) ---
# Example: postgresql://postgres:postgres@localhost:5432/expert_network
DATABASE_URL=postgresql://...

# --- Embeddings / LLM ---
OPENAI_API_KEY=sk-...
# Good defaults; can be changed without code changes
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_RANKING_MODEL=gpt-4.1-mini

# --- Retrieval ---
RETRIEVAL_TOP_K=10

# If pgvector isn't installed, set false to use local python cosine on stored vectors.
# (MVP fallback; pgvector recommended.)
USE_PGVECTOR=true

